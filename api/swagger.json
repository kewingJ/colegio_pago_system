{
  "openapi": "3.0.0",
  "info": {
    "title": "Sistema Escolar API",
    "description": "API para la gestión de alumnos, inscripciones y configuración del colegio.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api",
      "description": "Servidor Local"
    }
  ],
  "paths": {
    "/login.php": {
      "post": {
        "summary": "Autenticación de usuario",
        "tags": ["Autenticación"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "admin@example.com" },
                  "password": { "type": "string", "example": "123456" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login exitoso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "token": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/alumnos.php": {
      "get": {
        "summary": "Obtener lista completa de alumnos",
        "tags": ["Alumnos"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Lista de alumnos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "count": { "type": "integer" },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "integer" },
                          "carnet": { "type": "string" },
                          "nombre": { "type": "string" },
                          "padre": { "type": "string" },
                          "madre": { "type": "string" },
                          "contacto": {
                            "type": "object",
                            "properties": {
                              "telefono": { "type": "string" },
                              "email": { "type": "string" }
                            }
                          },
                          "academico": {
                            "type": "object",
                            "properties": {
                              "anio_lectivo": { "type": "string" },
                              "nivel": { "type": "string" },
                              "grado": { "type": "string" },
                              "seccion": { "type": "string" }
                            }
                          },
                          "estado": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/colegio.php": {
      "get": {
        "summary": "Obtener información del colegio",
        "tags": ["Configuración"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Datos del colegio",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "nombre": { "type": "string" },
                        "lema": { "type": "string" },
                        "direccion": { "type": "string" },
                        "telefonos": { "type": "string" },
                        "logo": { "type": "string", "nullable": true }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/niveles_grados.php": {
      "get": {
        "summary": "Obtener niveles con sus grados",
        "tags": ["Configuración"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Estructura académica",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "count": { "type": "integer" },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "integer" },
                          "nombre": { "type": "string" },
                          "mensualidad_base": { "type": "number" },
                          "grados": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "id": { "type": "integer" },
                                "nombre": { "type": "string" },
                                "cupo": { "type": "integer" }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}